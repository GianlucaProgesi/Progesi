<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <AssemblyName>ProgesiGrasshopperAssembly</AssemblyName>
    <RootNamespace>ProgesiGrasshopperAssembly</RootNamespace>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>

    <!-- output come nel tuo file -->
    <AppendTargetFrameworkToOutputPath>true</AppendTargetFrameworkToOutputPath>
    <OutDir>$(MSBuildProjectDirectory)\bin\$(Configuration)\net48\</OutDir>

    <!-- Switch: in CI usiamo pacchetti, in locale DLL installate -->
    <UseNugetRhino Condition="'$(UseNugetRhino)'==''">false</UseNugetRhino>
    <RhinoInstallDir Condition="'$(RhinoInstallDir)'==''">C:\Program Files\Rhino 8</RhinoInstallDir>
  </PropertyGroup>

  <!-- CI: pacchetti Rhino/Grasshopper (niente runtime, ci pensa Rhino a runtime) -->
  <ItemGroup Condition="'$(UseNugetRhino)'=='true'">
    <PackageReference Include="RhinoCommon" Version="8.*">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
    <PackageReference Include="Grasshopper" Version="8.*">
      <ExcludeAssets>runtime</ExcludeAssets>
    </PackageReference>
  </ItemGroup>

  <!-- Locale: DLL dall’installazione di Rhino 8 -->
  <ItemGroup Condition="'$(UseNugetRhino)'!='true'">
    <Reference Include="RhinoCommon">
      <HintPath>$(RhinoInstallDir)\System\RhinoCommon.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="GH_IO">
      <HintPath>$(RhinoInstallDir)\Plug-ins\Grasshopper\GH_IO.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Grasshopper">
      <HintPath>$(RhinoInstallDir)\Plug-ins\Grasshopper\Grasshopper.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!-- Riferimenti ai tuoi progetti usati dall'assembly GH -->
  <ItemGroup>
    <ProjectReference Include="..\ProgesiDataExchange\ProgesiDataExchange.csproj" />
    <ProjectReference Include="..\ProgesiCore\ProgesiCore.csproj" />
    <ProjectReference Include="..\ProgesiRepositories.Rhino\ProgesiRepositories.Rhino.csproj" />
    <ProjectReference Include="..\ProgesiRepositories.Sqlite\ProgesiRepositories.Sqlite.csproj" />
    <!-- >>> AGGIUNTO: in-memory repositories <<< -->
    <ProjectReference Include="..\ProgesiRepositories.InMemory\ProgesiRepositories.InMemory.csproj" />
  </ItemGroup>

  <!-- Pacchetti usati DIRETTAMENTE nell’assembly -->
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <!-- Icone: mantieni tutte le png con lo stesso LogicalName di prima -->
  <ItemGroup>
    <EmbeddedResource Include="Resources\*.png">
      <LogicalName>ProgesiGrasshopperAssembly.Resources.%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!-- Dopo build: rinomina dll in .gha accanto all’output -->
  <Target Name="PostBuildRenameToGha" AfterTargets="Build">
    <ItemGroup>
      <BuiltDll Include="$(OutDir)$(AssemblyName).dll" />
    </ItemGroup>
    <Copy SourceFiles="@(BuiltDll)" DestinationFiles="$(OutDir)$(AssemblyName).gha" SkipUnchangedFiles="true" />
  </Target>

</Project>
