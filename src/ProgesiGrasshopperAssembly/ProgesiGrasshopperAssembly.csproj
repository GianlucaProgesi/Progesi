<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Rhino 7: net48 -->
    <TargetFramework>net48</TargetFramework>

    <!-- Grasshopper add-on -->
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <TargetExt>.gha</TargetExt>

    <!-- Toolchain -->
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <LangVersion>8.0</LangVersion>
    <Nullable>enable</Nullable>
    <NoWarn>NU1701;NETSDK1086</NoWarn>
    <IsPackable>false</IsPackable>

    <!-- Copiare tutte le dipendenze nella cartella di output -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>

  <!-- WinForms abilitato per net48 / ambienti Windows -->
  <PropertyGroup Condition="$(TargetFramework.StartsWith('net4')) or $(TargetFramework.Contains('-windows'))">
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <ItemGroup>
    <!-- Stesse versioni che avevi nel progetto -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="rhinocommon" Version="8.21.25188.17001" />
    <PackageReference Include="Grasshopper" Version="8.21.25188.17001" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ProgesiDomainServices\ProgesiDomainServices.csproj" />
    <ProjectReference Include="..\ProgesiRepositories.InMemory\ProgesiRepositories.InMemory.csproj" />
    <ProjectReference Include="..\ProgesiRepositories.Rhino\ProgesiRepositories.Rhino.csproj" />
    <ProjectReference Include="..\ProgesiCore\ProgesiCore.csproj" />
    <ProjectReference Include="..\ProgesiRepositories.Sqlite\ProgesiRepositories.Sqlite.csproj" />
  </ItemGroup>

  <!-- ===== Deploy automatico in Grasshopper/Libraries/Progesi ===== -->
  <PropertyGroup>
    <GhDeployDir>$(APPDATA)\Grasshopper\Libraries\Progesi</GhDeployDir>
  </PropertyGroup>

  <Target Name="DeployGrasshopper" AfterTargets="Build">
    <Message Text="Deploying Grasshopper addon to '$(GhDeployDir)'" Importance="high" />
    <MakeDir Directories="$(GhDeployDir)" />

    <!-- Copia il file principale (.gha o .dll) -->
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(GhDeployDir)" SkipUnchangedFiles="true" />

    <!-- Copia le dipendenze locali che MSBuild mette in output -->
    <ItemGroup>
      <GhDeps Include="@(ReferenceCopyLocalPaths)" />
    </ItemGroup>
    <Copy SourceFiles="@(GhDeps)" DestinationFolder="$(GhDeployDir)" SkipUnchangedFiles="true" Condition="@(GhDeps) != ''" />

    <!-- Se il target è una .dll, crea anche la .gha affiancata -->
    <Copy SourceFiles="$(TargetPath)" DestinationFiles="$(GhDeployDir)\$(TargetName).gha" SkipUnchangedFiles="true" Condition="'$(TargetExt)'=='.dll'" />
  </Target>

</Project>
